        { "command": "vscode-svn.sparseCheckout.zh",          "when": "false" },
        { "command": "vscode-svn.removeIgnore.zh",            "when": "false" },
        { "command": "vscode-svn.quickSetProps.zh",           "when": "false" }
      ]
    },
    "configuration": {
      "title": "VSCode SVN",
      "properties": {
        "vscode-svn.language": {
          "type": "string",
          "enum": ["en", "zh"],
          "enumDescriptions": ["English", "中文"],
          "default": "en",
          "description": "SVN 菜单 / 面板文案语言 (English / 中文)"
        },
        "vscode-svn.customSvnRoot": {
          "type": "string",
          "default": null,
          "description": "自定义SVN工作副本根目录路径"
        },
        "vscode-svn.aiApiUrl": {
          "type": "string",
          "default": "",
          "description": "AI服务的API访问地址"
        },
        "vscode-svn.aiModelId": {
          "type": "string",
          "default": "",
          "description": "AI模型ID或名称"
        },
        "vscode-svn.aiApiKey": {
          "type": "string",
          "default": "",
          "description": "AI服务的API密钥"
        },
        "vscode-svn.aiLanguageModelId": {
          "type": "string",
          "default": "",
          "description": "IDE内置 AI 模型 ID（留空则自动选择，可填写如 deepseek, auto, ultimate 等）"
        },
        "vscode-svn.showUncommittedChanges": {
          "type": "boolean",
          "default": true,
          "description": "在日志列表中显示未提交到本地的修改"
        },
        "vscode-svn.showMissingFiles": {
          "type": "boolean",
          "default": true,
          "description": "在文件夹提交面板中显示丢失的文件（SVN中存在但本地已删除的文件）"
        },
        "vscode-svn.excludeFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "*.log",
            "*.tmp",
            "node_modules",
            ".DS_Store",
            "Thumbs.db"
          ],
          "description": "排除的文件和文件夹模式列表（支持glob模式）"
        },
        "vscode-svn.excludeFolders": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "node_modules",
            ".git",
            ".vscode",
            "dist",
            "build",
            "out",
            "target"
          ],
          "description": "排除的文件夹列表"
        },
        "vscode-svn.defaultFileEncoding": {
          "type": "string",
          "enum": [
            "auto",
            "utf8",
            "gbk",
            "gb2312",
            "big5",
            "latin1"
          ],
          "default": "auto",
          "description": "默认文件编码格式。auto表示自动检测，其他选项为强制使用指定编码"
        },
        "vscode-svn.forceUtf8Output": {
          "type": "boolean",
          "default": true,
          "description": "强制SVN命令输出使用UTF-8编码。建议保持开启以避免中文乱码"
        },
        "vscode-svn.enableEncodingDetection": {
          "type": "boolean",
          "default": true,
          "description": "启用文件编码自动检测。关闭后将使用默认编码"
        },
        "vscode-svn.encodingFallbacks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "utf8",
            "gbk",
            "gb2312",
            "big5"
          ],
          "description": "编码检测失败时的备用编码列表"
        },
        "vscode-svn.showEncodingInfo": {
          "type": "boolean",
          "default": false,
          "description": "在差异对比界面显示文件编码信息"
        },
        "vscode-svn.authenticationConfig.autoSaveCredentials": {
          "type": "boolean",
          "default": true,
          "description": "自动保存SVN认证信息"
        },
        "vscode-svn.authenticationConfig.defaultAuthPrompt": {
          "type": "boolean",
          "default": true,
          "description": "认证失败时自动提示输入用户名密码"
        },
        "vscode-svn.authenticationConfig.credentialTimeout": {
          "type": "number",
          "default": 86400,
          "description": "认证信息有效期（秒，0表示永不过期）"
        },
        "vscode-svn.authenticationConfig.serverPatterns": {
          "type": "object",
          "default": {},
          "description": "服务器URL匹配模式配置",
          "patternProperties": {
            ".*": {
              "type": "string",
              "description": "匹配模式对应的服务器根URL"
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npx tsc -p ./ && npm run copy-templates",
    "copy-templates": "mkdir -p out/templates && cp -r src/templates/* out/templates/ && mkdir -p templates && cp -r src/templates/* templates/",
    "watch": "npx tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
